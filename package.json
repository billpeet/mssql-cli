{
  "name": "@billpeet/mssql-cli",
  "version": "0.2.0",
  "description": "MSSQL CLI tool for AI agent and developer use",
  "author": "billpeet",
  "license": "MIT",
  "bin": {
    "mssql": "bin/mssql.js"
  },
